{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "type": "object",
  "properties": {
    "cron": {
      "description": "Cron pattern to use",
      "type": "string",
      "default": "0 0 0 * * *"
    },
    "cup_base_url": {
      "description": "Base URL of Cup's instance",
      "type": "string"
    },
    "webhook_url": {
      "description": "Discord's webhook URL to which send request",
      "type": "string"
    }
  },
  "required": [
    "webhook_url",
    "cup_base_url"
  ]
}